import fs from 'node:fs';
import path from 'node:path';
import { runFile } from './runner.js';

export async function runTests(target = '.') {
  const root = path.resolve(process.cwd(), target);
  const files = collectTestFiles(root);

  if (files.length === 0) {
    console.log('No test files found (*_test.krs or tests/*.krs)');
    return;
  }

  console.log(`Running ${files.length} test file(s)...\n`);
  let failed = 0;

  for (const file of files) {
    try {
      await runFile(file);
      console.log(`  ✓ ${path.relative(root, file)}`);
    } catch (e) {
      failed++;
      console.log(`  ✗ ${path.relative(root, file)} — ${e.message}`);
    }
  }

  console.log('');
  if (failed > 0) {
    console.log(`${failed} file(s) failed`);
    process.exit(1);
  }
  console.log('All tests passed');
}

function collectTestFiles(dir) {
  const out = [];
  if (!fs.existsSync(dir)) return out;

  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    const full = path.join(dir, entry.name);
    if (entry.isDirectory() && !entry.name.startsWith('.') && entry.name !== 'node_modules') {
      out.push(...collectTestFiles(full));
    } else if (entry.isFile() && entry.name.endsWith('_test.krs')) {
      out.push(full);
    }
  }
  return out.sort();
}
