{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Krs",
  "scopeName": "source.krs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#modules" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.krs",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.krs" }
          }
        },
        {
          "name": "comment.line.double-slash.krs",
          "match": "//.*$",
          "captures": {
            "0": { "name": "comment.line.krs" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.template.krs",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.embedded.expression.krs",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            },
            {
              "name": "constant.character.escape.krs",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.double.krs",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.krs",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.krs",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.krs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.krs",
          "match": "\\b(if|then|else|elseif|end|while|until|for|each|in|break|continue|return|try|catch|finally|throw|async|await|repeat|times|guard|unless)\\b"
        },
        {
          "name": "keyword.declaration.krs",
          "match": "\\b(let|const|fn|class|extends|static|enum|export|default)\\b"
        },
        {
          "name": "keyword.operator.logical.krs",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.other.krs",
          "match": "\\b(from|into|as|new|this|self|super)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.krs",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.krs",
          "match": "\\b(null|undefined)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.krs",
          "match": "\\b(number|string|bool|boolean|void|any|null|object|array)\\b"
        },
        {
          "name": "entity.name.type.krs",
          "match": "(?<=:\\s*)[A-Z][a-zA-Z0-9_]*"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.krs",
          "match": "(?<=\\bfn\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.function.call.krs",
          "match": "(?<=[^\\.]\\b)[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.krs",
          "match": "\\b(print|println|log|range|map|filter|reduce|Ok|Err)\\b(?=\\s*\\()"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "keyword.control.import.krs",
          "match": "\\b(use|loadAll|import|require)\\b"
        },
        {
          "name": "string.unquoted.module-path.krs",
          "match": "(?<=(use|loadAll|from)\\s+\")[^\"]+(?=\")"
        },
        {
          "name": "variable.other.constant.module.krs",
          "match": "(?<=(use|import)\\s+stdlib\\.)[a-z]+"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.krs",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.krs",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.optional.krs",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.ternary.krs",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.krs",
          "match": "(===|!==|==|!=|<=|>=|=>|\\+\\+|--|\\*\\*|\\.\\.\\.)"
        },
        {
          "name": "keyword.operator.arithmetic.krs",
          "match": "[+\\-*/%=<>:!&|]"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.krs",
          "match": "\\b(self|this)\\b"
        },
        {
          "name": "variable.other.property.krs",
          "match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.readwrite.krs",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
